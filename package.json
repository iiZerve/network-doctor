{
  "name": "network-doctor",
  "version": "1.0.0",
  "description": "Network Doctor - Advanced local network diagnostics for Android",
  "main": "index.js",
  "scripts": {
    "cap": "npx cap",
    "sync": "npx cap sync",
    "prepare:web": "node -e \"require('fs').copyFileSync('index.html','www/index.html')\"",
    "build:android:debug": "node scripts/build-android.js debug",
    "build:android:release": "node scripts/build-android.js release",
    "open:android": "npx cap open android",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "network",
    "diagnostics",
    "monitoring",
    "capacitor",
    "android"
  ],
  "author": "iiZerve",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}